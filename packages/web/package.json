{
  "name": "planora-web",
  "version": "0.1.2",
  "description": "Planora web dashboard — React app with mind maps and architecture diagrams",
  "license": "MIT",
  "author": "kubabb <kubarogoz3@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kubabb/Planora.git"
  },
  "keywords": ["planora", "dashboard", "mindmap", "mermaid", "react"],
  "engines": { "node": ">=20" },
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "./dist/index.html",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --noEmit && vite build .",
    "dev": "vite . --host 127.0.0.1 --port 4173",
    "preview": "vite preview . --host 127.0.0.1 --port 4173",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "exports": {
    ".": "./dist/index.html",
    "./package.json": "./package.json"
  },
  "dependencies": {
    "markmap-lib": "^0.18.12",
    "markmap-view": "^0.18.12",
    "mermaid": "^11.15.0",
    "react": "^18",
    "react-dom": "^18",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "typescript": "^5.4",
    "vite": "^5"
  }
}
