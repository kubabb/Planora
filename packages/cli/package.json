{
  "name": "@planora/cli",
  "version": "0.1.0",
  "description": "Planora CLI — AI-powered project planning, mind maps, and architecture diagrams",
  "license": "MIT",
  "author": "kubabb <kubarogoz3@gmail.com>",
  "repository": "github:kubabb/Planora",
  "keywords": ["planora", "cli", "project-planning", "ai", "mermaid", "mindmap"],
  "engines": { "node": ">=20" },
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "planora": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "dependencies": {
    "@planora/core": "^0.1.0",
    "@planora/runner": "^0.1.0",
    "@planora/web": "^0.1.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4",
    "@types/node": "^20"
  }
}
