{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "planora-core": ["packages/core/src/index.ts"],
      "planora-runner": ["packages/runner/src/index.ts"],
      "planora-web/*": ["packages/web/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
